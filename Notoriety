task.spawn(function()
    -- 获取并加上房卡的路径 / Add KeyCard to paths
    local map = Workspace:WaitForChild("Map", 10)
    local mapEntities = Workspace:WaitForChild("mapEntities", 10)
    
    local keycard = map and map:WaitForChild("KeyCard", 5):WaitForChild("KeyCard", 5)
    local hooks = mapEntities and mapEntities:WaitForChild("missionItems", 5):WaitForChild("Hooks", 5):WaitForChild("missionItem_hook", 5)
    local ropes = mapEntities and mapEntities:WaitForChild("missionItems", 5):WaitForChild("Ropes", 5):WaitForChild("missionItem_rope", 5)
    
    local targets = {hooks, ropes, keycard}
    
    for _, object in ipairs(targets) do
        if object then
            local highlight = Instance.new("Highlight")
            highlight.Name = "MissionHighlight"
            highlight.FillColor = Color3.fromRGB(0, 255, 0) 
            highlight.FillTransparency = 0.4 
            highlight.OutlineTransparency = 1 
            highlight.Adornee = object
            highlight.Parent = object
        end
    end
end)
