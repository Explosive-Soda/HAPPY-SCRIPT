-- 2. 核心解密逻辑 / Core Decryption Logic
----------------------------------------------------------------
task.spawn(function()
    local mainCardReader = Workspace:WaitForChild("prop_stadium_cardReader", 10)
    if not mainCardReader then 
        line1.Text = "Main Path Error"
        return 
    end
    
    local mainLabel = mainCardReader:WaitForChild("main", 5):WaitForChild("serial", 5):WaitForChild("SurfaceGui", 5):WaitForChild("TextLabel", 5)

    local function getBlueprintFolder()
        local bp = Workspace:FindFirstChild("Blueprints")
        if bp then
            local tableRNG = bp:FindFirstChild("prop_stadium_blueprintTableRNG")
            if tableRNG then
                return tableRNG:FindFirstChild("prop_stadium_blueprint")
            end
        end
        return nil
    end

    local function checkAndMatch()
        local currentSerial = mainLabel.Text
        line1.Text = "Serial: " .. currentSerial

        if currentSerial == "" or currentSerial == "Label" or currentSerial == "TextLabel" then
            line2.Text = "Colors: Idle..."
            return
        end

        local blueprintsFolder = getBlueprintFolder()
        if not blueprintsFolder then
            line2.Text = "Colors: Path Error"
            return
        end

        for _, numName in ipairs({"1", "2", "3"}) do
            local numFolder = blueprintsFolder:FindFirstChild(numName)
            if numFolder then
                local success, subLabel = pcall(function()
                    return numFolder:FindFirstChild("serial"):FindFirstChild("SurfaceGui"):FindFirstChild("TextLabel")
                end)

                if success and subLabel and subLabel.Text == currentSerial then
                    local colorResult = ""
                    
                    for i = 1, 4 do
                        local successColor, colorLabel = pcall(function()
                            local colorsDir = numFolder:FindFirstChild("colors")
                            local part = colorsDir:FindFirstChild(tostring(i))
                            return part:FindFirstChild("SurfaceGui"):FindFirstChild("TextLabel")
                        end)

                        if successColor and colorLabel then
                            colorResult = colorResult .. tostring(colorLabel.Text)
                        else
                            colorResult = colorResult .. "?"
                        end
                    end
                    
                    line2.Text = "Colors: " .. colorResult
                    return
                end
            end
        end
        line2.Text = "Colors: No Match Found"
    end

    mainLabel:GetPropertyChangedSignal("Text"):Connect(checkAndMatch)
    
    while true do
        checkAndMatch()
        task.wait(1.5)
    end
end)

