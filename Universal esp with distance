-- 更新 Box 和 Distance ESP
local function updateDrawings()
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character:FindFirstChild("HumanoidRootPart") then
			local char = player.Character
			local hrp = char.HumanoidRootPart
			local alive = char.Humanoid.Health > 0
			local isEnemy = not teamCheck or player.TeamColor ~= LocalPlayer.TeamColor

			if alive and isEnemy then
				local head = char:FindFirstChild("Head")
				local torso = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
				
				if head and torso then
					local hrpPos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(hrp.Position)
					
					-- 1. 处理 Box ESP
					if boxESPEnabled and onScreen then
						if not boxESPDrawings[player] then
							local box = {Top = Drawing.new("Line"), Bottom = Drawing.new("Line"), Left = Drawing.new("Line"), Right = Drawing.new("Line")}
							for _, line in pairs(box) do line.Thickness = boxThickness; line.Color = boxColor; line.Visible = true end
							boxESPDrawings[player] = box
						end
						
						local headPos = workspace.CurrentCamera:WorldToViewportPoint(head.Position)
						local torsoPos = workspace.CurrentCamera:WorldToViewportPoint(torso.Position)
						local height = math.abs(headPos.Y - torsoPos.Y) * 2.5
						local width = height * 0.6
						local topY, bottomY = headPos.Y - height * 0.3, torsoPos.Y + height * 0.2
						local leftX, rightX = torsoPos.X - width / 2, torsoPos.X + width / 2
						
						local box = boxESPDrawings[player]
						if box.Top then box.Top.From, box.Top.To = Vector2.new(leftX, topY), Vector2.new(rightX, topY) end
						if box.Bottom then box.Bottom.From, box.Bottom.To = Vector2.new(leftX, bottomY), Vector2.new(rightX, bottomY) end
						if box.Left then box.Left.From, box.Left.To = Vector2.new(leftX, topY), Vector2.new(leftX, bottomY) end
						if box.Right then box.Right.From, box.Right.To = Vector2.new(rightX, topY), Vector2.new(rightX, bottomY) end
						for _, line in pairs(box) do if line then line.Visible = true end end
					else
						if boxESPDrawings[player] then
							for _, line in pairs(boxESPDrawings[player]) do if line then line.Visible = false end end
						end
					end

					-- 2. 处理 Distance ESP
					if distanceESPEnabled and onScreen and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
						if not distanceDrawings[player] then
							local text = Drawing.new("Text")
							text.Size = 16
							text.Center = true
							text.Outline = true
							text.OutlineColor = Color3.new(0, 0, 0)
							text.Color = distanceColor
							text.Visible = true
							distanceDrawings[player] = text
						end
						
						local myHrp = LocalPlayer.Character.HumanoidRootPart
						local dist = math.floor((hrp.Position - myHrp.Position).Magnitude)
						local headPos = workspace.CurrentCamera:WorldToViewportPoint(head.Position)
						
						local text = distanceDrawings[player]
						text.Text = "[" .. tostring(dist) .. " studs]"
						text.Position = Vector2.new(headPos.X, headPos.Y - 25) -- 显示在头顶上方
						text.Visible = true
					else
						if distanceDrawings[player] then distanceDrawings[player].Visible = false end
					end
				end
			else
				-- 玩家死亡或不符条件，隐藏
				if boxESPDrawings[player] then
					for _, line in pairs(boxESPDrawings[player]) do if line then line.Visible = false end end
				end
				if distanceDrawings[player] then distanceDrawings[player].Visible = false end
			end
		else
			-- 玩家不存在，清理 Drawing 实例防止内存泄漏
			if boxESPDrawings[player] then
				for _, line in pairs(boxESPDrawings[player]) do if line then line:Remove() end end
				boxESPDrawings[player] = nil
			end
			if distanceDrawings[player] then
				distanceDrawings[player]:Remove()
				distanceDrawings[player] = nil
			end
		end
	end
end

-- 玩家离开清理
local function removePlayerDrawings(player)
	if boxESPDrawings[player] then
		for _, line in pairs(boxESPDrawings[player]) do if line then line:Remove() end end
		boxESPDrawings[player] = nil
	end
	if distanceDrawings[player] then
		distanceDrawings[player]:Remove()
		distanceDrawings[player] = nil
	end
end

Players.PlayerRemoving:Connect(removePlayerDrawings)

-- 显隐与拖拽
UserInputService.InputBegan:Connect(function(input, gp)
	if not gp and input.KeyCode == hideKey then frame.Visible = not frame.Visible end
end)

local dragging, dragStart, startPos = false, nil, nil
frame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true; dragStart = input.Position; startPos = frame.Position
	end
end)
frame.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)
frame.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

-- 核心渲染循环
RunService.RenderStepped:Connect(function()
	-- Highlight ESP 逻辑保持不变
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") then
			local char = player.Character
			if char.Humanoid.Health > 0 and (not teamCheck or player.TeamColor ~= LocalPlayer.TeamColor) then
				local hl = char:FindFirstChild("Highlight") or Instance.new("Highlight", char)
				hl.FillColor = color
				hl.OutlineColor = Color3.new(0, 0, 0)
				hl.OutlineTransparency = 0.5
				hl.Enabled = espEnabled
				hl.Adornee = char
			else
				if char:FindFirstChild("Highlight") then char.Highlight.Enabled = false end
			end
		end
	end
	
	-- 刷新 Drawing (Box & Distance)
	updateDrawings()
end)

-- 全局清理
LocalPlayer:GetPropertyChangedSignal("Parent"):Connect(function()
	if not LocalPlayer.Parent then
		for _, v in pairs(boxESPDrawings) do for _, line in pairs(v) do if line then line:Remove() end end end
		for _, text in pairs(distanceDrawings) do if text then text:Remove() end end
	end
end)
