local UIS = game:GetService("UserInputService")
local coreGui = game:GetService("CoreGui")
local players = game:GetService("Players")

-- 清理旧的 / Clean up old GUI
if coreGui:FindFirstChild("WendigoESP_Gui") then
	coreGui.WendigoESP_Gui:Destroy()
end

-- 1. 创建 GUI 容器 / Create GUI Container
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "WendigoESP_Gui"
screenGui.ResetOnSpawn = false
screenGui.Parent = coreGui

-- 2. 主面板 / Main Frame
local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 140, 0, 150)
mainFrame.Position = UDim2.new(0.05, 0, 0.05, 0)
mainFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
mainFrame.BorderSizePixel = 0
mainFrame.Active = true
mainFrame.Draggable = true
mainFrame.Parent = screenGui

-- 封装一个统一的开关按钮样式生成器 / Helper to create toggle rows
local function createToggleRow(text, yOffset)
	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(0.65, 0, 0, 30)
	title.Position = UDim2.new(0, 8, 0, yOffset)
	title.Text = text
	title.TextColor3 = Color3.fromRGB(255, 255, 255)
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.Font = Enum.Font.SourceSansBold
	title.TextSize = 13
	title.BackgroundTransparency = 1
	title.Parent = mainFrame

	local button = Instance.new("TextButton")
	button.Size = UDim2.new(0, 22, 0, 22)
	button.Position = UDim2.new(1, -28, 0, yOffset + 4)
	button.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	button.BorderSizePixel = 0
	button.Text = ""
	button.Font = Enum.Font.SourceSansBold
	button.TextSize = 16
	button.Parent = mainFrame

	return button
end

local button1 = createToggleRow("Wendigo ESP", 5)
local button2 = createToggleRow("Item ESP", 40)
local button3 = createToggleRow("Player ESP", 75)
local button4 = createToggleRow("Chest ESP", 110)

-- ==================== TOGGLE 1: WENDIGO ESP ====================
local t1_on = false

local function applyWendigoHighlight(target)
	if not target or not t1_on then return end
	local hl = target:FindFirstChild("WendigoHighlight")
	if not hl then
		hl = Instance.new("Highlight")
		hl.Name = "WendigoHighlight"
		hl.FillColor = Color3.fromRGB(255, 0, 0)
		hl.FillTransparency = 0.8
		hl.OutlineTransparency = 1
		hl.Parent = target
	end
	hl.Enabled = true
end

button1.MouseButton1Click:Connect(function()
	t1_on = not t1_on
	local aiFolder = workspace:FindFirstChild("AI")
	local wendigo = aiFolder and aiFolder:FindFirstChild("WendigoAI")
	
	if t1_on then
		button1.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
		button1.Text = "✓"
		button1.TextColor3 = Color3.fromRGB(255, 255, 255)
		if wendigo then applyWendigoHighlight(wendigo) end
	else
		button1.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		button1.Text = ""
		if wendigo and wendigo:FindFirstChild("WendigoHighlight") then
			wendigo.WendigoHighlight.Enabled = false
		end
	end
end)

task.spawn(function()
	local aiFolder = workspace:WaitForChild("AI", 5)
	if aiFolder then
		aiFolder.ChildAdded:Connect(function(child)
			if child.Name == "WendigoAI" then
				task.wait(0.2)
				applyWendigoHighlight(child)
			end
		end)
	end
end)

-- ==================== TOGGLE 2: ITEM ESP ====================
local t2_on = false

local function highlightItem(item)
	if item:IsA("Model") or item:IsA("BasePart") then
		local hl = item:FindFirstChild("ItemHighlight")
		if not hl then
			hl = Instance.new("Highlight")
			hl.Name = "ItemHighlight"
			hl.FillColor = Color3.fromRGB(144, 238, 144)
			hl.FillTransparency = 0.9
			hl.OutlineTransparency = 1
			hl.Parent = item
		end
		hl.Enabled = t2_on
	end
end

button2.MouseButton1Click:Connect(function()
	t2_on = not t2_on
	local itemFolder = workspace:FindFirstChild("ItemSpawners") and workspace.ItemSpawners:FindFirstChild("ShopItemPickups")
	if itemFolder then
		for _, child in ipairs(itemFolder:GetChildren()) do highlightItem(child) end
	end
	
	if t2_on then
		button2.BackgroundColor3 = Color3.fromRGB(144, 238, 144)
		button2.Text = "✓"
		button2.TextColor3 = Color3.fromRGB(40, 40, 40)
	else
		button2.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		button2.Text = ""
	end
end)

task.spawn(function()
	local itemFolder = workspace:WaitForChild("ItemSpawners", 5) and workspace.ItemSpawners:WaitForChild("ShopItemPickups", 5)
	if itemFolder then
		itemFolder.ChildAdded:Connect(function(child)
			task.wait(0.1)
			highlightItem(child)
		end)
	end
end)

-- ==================== TOGGLE 3: PLAYER ESP ====================
local t3_on = false

local function highlightPlayer(plr)
	if plr == players.LocalPlayer then return end 
	local function apply(char)
		if not char then return end
		local hl = char:FindFirstChild("PlayerHighlight")
		if not hl then
			hl = Instance.new("Highlight")
			hl.Name = "PlayerHighlight"
			hl.FillColor = Color3.fromRGB(255, 255, 255)
			hl.FillTransparency = 0.85
			hl.OutlineTransparency = 1
			hl.Parent = char
		end
		hl.Enabled = t3_on
	end
	apply(plr.Character)
	plr.CharacterAdded:Connect(apply)
end

button3.MouseButton1Click:Connect(function()
	t3_on = not t3_on
	for _, plr in ipairs(players:GetPlayers()) do highlightPlayer(plr) end
	
	if t3_on then
		button3.BackgroundColor3 = Color3.fromRGB(120, 120, 120)
		button3.Text = "✓"
		button3.TextColor3 = Color3.fromRGB(255, 255, 255)
	else
		button3.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		button3.Text = ""
	end
end)

players.PlayerAdded:Connect(function(plr) highlightPlayer(plr) end)

-- ==================== TOGGLE 4: CHEST ESP ====================
local t4_on = false
local chestColor = Color3.fromRGB(173, 216, 230) -- 浅蓝色

local function applyChestHighlight(obj)
	if not obj or not (obj:IsA("Model") or obj:IsA("BasePart")) then return end
	local hl = obj:FindFirstChild("ChestHighlight")
	if not hl then
		hl = Instance.new("Highlight")
		hl.Name = "ChestHighlight"
		hl.FillColor = chestColor
		hl.FillTransparency = 0.85
		hl.OutlineTransparency = 1
		hl.Parent = obj
	end
	hl.Enabled = t4_on
end

local function updateCaches()
	local cachesFolder = workspace:FindFirstChild("Caches")
	if cachesFolder then
		-- 1. 直接高亮 CacheBox 整体 / Directly highlight the entire CacheBox
		local cacheBox = cachesFolder:FindFirstChild("CacheBox")
		if cacheBox then applyChestHighlight(cacheBox) end
		
		-- 2. 检查 Paper
		local paper = cachesFolder:FindFirstChild("Paper")
		if paper then applyChestHighlight(paper) end
	end
end

button4.MouseButton1Click:Connect(function()
	t4_on = not t4_on
	updateCaches()
	
	if t4_on then
		button4.BackgroundColor3 = chestColor
		button4.Text = "✓"
		button4.TextColor3 = Color3.fromRGB(40, 40, 40)
	else
		button4.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		button4.Text = ""
	end
end)

-- 动态监听，确保即使游戏跨局重刷也能捕捉到整个 CacheBox
task.spawn(function()
	local cachesFolder = workspace:WaitForChild("Caches", 5)
	if cachesFolder then
		cachesFolder.ChildAdded:Connect(function(child)
			-- 监听 Paper 或整个 CacheBox 生成 / Watch for Paper or the entire CacheBox
			if child.Name == "Paper" or child.Name == "CacheBox" then
				task.wait(0.1)
				applyChestHighlight(child)
			end
		end)
	end
end)

-- ==================== GLOBAL HOTKEY ====================
UIS.InputBegan:Connect(function(input, gameProcessed)
	if not gameProcessed and input.KeyCode == Enum.KeyCode.RightAlt then
		mainFrame.Visible = not mainFrame.Visible
	end
end)
